# Optional API keys for broader collection.
# Public RSS and Google News RSS work without these.

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

X_BEARER_TOKEN=

# Google Gemini API hosted Gemma.
# Do not commit real tokens.
HF_TOKEN=
