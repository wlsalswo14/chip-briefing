# Optional API keys for broader collection.
# Public RSS and Google News RSS work without these.

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

X_BEARER_TOKEN=

# Hugging Face Inference Providers / OpenAI-compatible router.
# Do not commit real tokens.
HF_TOKEN=
CHIP_BRIEFING_LLM_BASE_URL=https://router.huggingface.co/v1
CHIP_BRIEFING_LLM_MODEL=google/gemma-4-26B-A4B-it
CHIP_BRIEFING_LLM_MAX_ITEMS=36
CHIP_BRIEFING_LLM_TIMEOUT=45

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SEND_RUN_LOG=1
TELEGRAM_TIMEOUT=20

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=chip-briefing-local/1.0

# Optional tuning
CHIP_BRIEFING_MAX_ITEMS=36
CHIP_BRIEFING_TIMEOUT=15
